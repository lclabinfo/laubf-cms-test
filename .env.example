# ===========================================
# Digital Church CMS — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# Required variables are marked with [REQUIRED].
# Optional variables have sensible defaults or enable optional features.

# ---------- Database [REQUIRED] ----------
DATABASE_URL="postgresql://user:password@localhost:5432/digitalchurch?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/digitalchurch?schema=public"

# ---------- Church Tenant [REQUIRED] ----------
# Single-tenant MVP: resolves to church UUID via DB lookup.
CHURCH_SLUG=la-ubf

# ---------- Authentication (Auth.js v5) [REQUIRED] ----------
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET=generate-a-random-secret-here
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ---------- Google OAuth (optional) ----------
# Create credentials at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---------- Test Credentials (development only) ----------
# Used by prisma/seed.mts to create a test user
AUTH_TEST_EMAIL=info@lclab.io
AUTH_TEST_PASSWORD=admin123

# ---------- Azure OpenAI (optional) ----------
# Enables AI-powered transcript features (auto-alignment, caption cleanup)
# Create a resource at https://portal.azure.com/#create/Microsoft.CognitiveServicesOpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ---------- YouTube Data API (optional) ----------
# Enables YouTube caption import in the video editor
# Get an API key at https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# ---------- Cloudflare R2 Storage (optional) ----------
# Enables file uploads for media library and bible study attachments.
# Create a bucket at https://dash.cloudflare.com > R2.
# Create an S3-compatible API token at R2 > Manage R2 API Tokens.
# See docs/06_r2-storage/01-r2-env-setup.md for full setup guide.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=digitalchurch-media
R2_PUBLIC_URL=
